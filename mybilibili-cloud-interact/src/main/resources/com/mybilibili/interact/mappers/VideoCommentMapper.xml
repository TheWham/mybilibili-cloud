    <select id="selectByCommentId" resultMap="base_result_map">
        SELECT <include refid="base_column_list"/>
        FROM video_comment v WHERE v.comment_id=#{commentId}
    </select>

    <delete id="deleteByCommentId">
        DELETE FROM video_comment
        WHERE comment_id=#{commentId} OR p_comment_id = #{commentId}
    </delete>

    <update id="updateByCommentId" parameterType="com.mybilibili.interact.entity.po.VideoComment">
        UPDATE video_comment
        <set>
            <if test="bean.pCommentId != null">p_comment_id = #{bean.pCommentId},</if>
            <if test="bean.videoId != null">video_id = #{bean.videoId},</if>
            <if test="bean.videoUserId != null">video_user_id = #{bean.videoUserId},</if>
            <if test="bean.content != null">content = #{bean.content},</if>
            <if test="bean.imgPath != null">img_path = #{bean.imgPath},</if>
            <if test="bean.userId != null">user_id = #{bean.userId},</if>
            <if test="bean.replyUserId != null">reply_user_id = #{bean.replyUserId},</if>
            <if test="bean.topType != null">top_type = #{bean.topType},</if>
            <if test="bean.postTime != null">post_time = #{bean.postTime},</if>
            <if test="bean.likeCount != null">like_count = #{bean.likeCount},</if>
            <if test="bean.hateCount != null">hate_count = #{bean.hateCount},</if>
        </set>
        WHERE comment_id=#{commentId}
    </update>

    <update id="updateCount">
        UPDATE video_comment
        SET like_count = like_count + #{likeDiff}, hate_count = hate_count + #{hateDiff}
        WHERE comment_id = #{commentId}
    </update>

    <update id="updateCountBatch">
        UPDATE video_comment
        SET like_count =
        CASE comment_id
            <foreach collection="list" item="item">
                WHEN #{item.commentId} THEN like_count + #{item.likeDiff}
            </foreach>
        END,
        hate_count =
        CASE comment_id
            <foreach collection="list" item="item">
                WHEN #{item.commentId} THEN hate_count + #{item.hateDiff}
            </foreach>
        END
        WHERE comment_id IN
        <foreach collection="list" item="item" open="(" separator="," close=")">
            #{item.commentId}
        </foreach>
    </update>
