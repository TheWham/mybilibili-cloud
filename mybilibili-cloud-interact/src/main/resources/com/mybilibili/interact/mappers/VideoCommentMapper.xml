    <insert id="insertBatch" parameterType="com.mybilibili.interact.entity.po.VideoComment" useGeneratedKeys="true" keyProperty="commentId">
        INSERT INTO video_comment(comment_id,p_comment_id,video_id,video_user_id,content,img_path,user_id,reply_user_id,top_type,post_time,like_count,hate_count) values
        <foreach collection="list" item="item" separator=",">
            (#{item.commentId},#{item.pCommentId},#{item.videoId},#{item.videoUserId},#{item.content},#{item.imgPath},#{item.userId},#{item.replyUserId},#{item.topType},#{item.postTime},#{item.likeCount},#{item.hateCount})
        </foreach>
